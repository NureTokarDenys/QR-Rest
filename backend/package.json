{
  "name": "qr-restaurant-api",
  "version": "1.0.0",
  "description": "QR-based contactless food ordering REST API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "lint": "eslint src/",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch --runInBand",
    "test:coverage": "jest --runInBand --forceExit --coverage",
    "integration:s3": "node tests/integration/s3.integration.js",
    "integration:google": "node tests/integration/google-oauth.integration.js",
    "integration:liqpay": "node tests/integration/liqpay.integration.js",
    "integration:email": "node tests/integration/email.integration.js",
    "integration:translate": "node tests/integration/translate.integration.js",
    "db:seed": "node scripts/db-seed.js",
    "db:seed-orders": "node scripts/db-seed-orders.js",
    "db:fix-roles": "node scripts/fix-admin-roles.js",
    "db:backup": "node scripts/db-backup.js",
    "db:restore": "node scripts/db-restore.js"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 15000,
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "globalSetup": "./tests/setup/globalSetup.js",
    "globalTeardown": "./tests/setup/globalTeardown.js",
    "setupFiles": [
      "./tests/setup/env.js"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/tests/"
    ]
  },
  "dependencies": {
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "aws-sdk": "^2.1493.0",
    "axios": "^1.6.0",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.2.0",
    "mongoose": "^9.6.1",
    "multer": "^1.4.5-lts.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.14.0",
    "qrcode": "^1.5.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "resend": "^6.12.3",
    "sanitize-html": "^2.11.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.1.6",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
